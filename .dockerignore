# Keep Docker build context predictable for Railway/Railpack.
# Avoid whitelist-style patterns with `*` + negations, which can be expanded
# by some builders into invalid copy targets like `/app/**`.

# VCS and local tooling
.git
.github
.vscode
.devcontainer

# Dependencies and build caches
node_modules
**/node_modules
.pnpm-store
.turbo

# Local env files
.env
.env.*
!.env.local.example

# Logs and temporary files
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
